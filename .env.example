# ============================================================
# Gestionale Palestra — Configurazione .env
# Copia questo file in .env e modifica i valori sensibili.
# NON committare il file .env nel repository.
# ============================================================

# Ambiente (development | production)
NODE_ENV=production

# Porta HTTP del server Node (Nginx reverse proxy ascolta su :80)
PORT=3000

# Segreto per express-session — OBBLIGATORIO cambiarlo in produzione
# Genera con: openssl rand -base64 48
SESSION_SECRET=CAMBIA-QUESTO-VALORE-LUNGO-E-CASUALE

# Admin iniziale creato da npm run db:seed
INITIAL_ADMIN_USERNAME=sonny.lupica
# Scegli una password sicura — obbligatoria, il seed fallisce se mancante
INITIAL_ADMIN_PASSWORD=CAMBIA-QUESTA-PASSWORD

# Path database SQLite (relativo alla root progetto)
DB_PATH=./data/gestionale.sqlite

# Cartelle locali per backup ed export
BACKUP_DIR=./backups
EXPORT_DIR=./exports

# Backup automatico (node-cron)
BACKUP_ENABLED=true
# Espressione cron (default: ogni giorno alle 03:00)
BACKUP_CRON=0 3 * * *
# Retention prudente: cancella backup auto/manual piu' vecchi di N giorni
# (mai i pre_restore; mantiene comunque almeno BACKUP_MIN_KEEP file). 0 = disattiva.
BACKUP_RETENTION_DAYS=30
BACKUP_MIN_KEEP=5

# Token statico per proteggere POST /api/nfc/check dal lettore NFC fisico.
# Lascia vuoto per disabilitare (comportamento pubblico invariato).
# Se configurato, il lettore deve inviare: X-NFC-Token: <valore>
# Le sessioni admin (simulatore) non richiedono questo token.
# Genera con: openssl rand -hex 32
NFC_API_TOKEN=
